# ── Server ──────────────────────────────────────────────
APP_ENV=development
APP_PORT=8080
APP_NAME="Distribution Management System"
# Comma-separated list of allowed origins for CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# ── Database (PostgreSQL) ───────────────────────────────
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=distribution
DB_SSLMODE=disable
DB_TIMEZONE=Asia/Kolkata

# ── JWT ─────────────────────────────────────────────────
JWT_ACCESS_SECRET=super-secret-access-key-change-me
JWT_REFRESH_SECRET=super-secret-refresh-key-change-me
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# ── Storage (local | s3) ────────────────────────────────
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=./uploads
STORAGE_PUBLIC_URL=http://localhost:8080/uploads
# S3 (used when STORAGE_DRIVER=s3) — fill in later
S3_BUCKET=
S3_REGION=
S3_ACCESS_KEY=
S3_SECRET_KEY=
S3_ENDPOINT=

# ── Seed (first run) ────────────────────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@company.com
SEED_SUPERADMIN_PASSWORD=ChangeMe@123
SEED_SUPERADMIN_NAME=Super Admin
