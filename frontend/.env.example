# Base URL of the Go API.
#
# Local dev (backend on localhost:8080, Vite proxies /api):
#   VITE_API_BASE_URL=/api/v1
#
# EC2 backend (direct):
#   VITE_API_BASE_URL=http://13.238.218.254:8080/api/v1
#
# Vercel (vercel.json proxies /api to EC2 — keep /api/v1):
#   VITE_API_BASE_URL=/api/v1
VITE_API_BASE_URL=http://13.238.218.254:8080/api/v1
