# Copy to .env.aws on your EC2 server, then edit values.
# cp .env.aws.example .env.aws
#
# IMPORTANT: POSTGRES_PASSWORD and DB_PASSWORD must match.
# If you change the password after the first deploy, run:
#   docker-compose -f docker-compose.aws.yml down -v
#   docker-compose -f docker-compose.aws.yml up --build -d

# ── Postgres container (docker postgres image) ───────────
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=distribution

# ── Backend DB connection (must match POSTGRES_* above) ───
DB_USER=postgres
DB_PASSWORD=postgres
DB_NAME=distribution
DB_TIMEZONE=Asia/Kolkata

# ── CORS ──────────────────────────────────────────────────
CORS_ORIGINS=*

# ── Uploaded images (Vercel proxies /uploads to EC2) ─────
STORAGE_PUBLIC_URL=/uploads

# ── JWT (use long random strings in production) ───────────
JWT_ACCESS_SECRET=change-me-long-random-access-secret
JWT_REFRESH_SECRET=change-me-long-random-refresh-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# ── Seed super admin (first run only) ─────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@company.com
SEED_SUPERADMIN_PASSWORD=ChangeMe@123
SEED_SUPERADMIN_NAME="Super Admin"
