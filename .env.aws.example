# Copy to .env.aws on your EC2 server, then edit values.
# cp .env.aws.example .env.aws

# ── Vercel frontend URL (for CORS) ──────────────────────
# Use your production Vercel URL, no trailing slash.
CORS_ORIGINS=https://your-app.vercel.app

# ── Backend public URL (for uploaded images) ──────────────
# Must match the host used in Vercel VITE_API_BASE_URL (without /api/v1).
# Use HTTPS in production (Cloudflare or Certbot on EC2).
STORAGE_PUBLIC_URL=https://api.yourdomain.com/uploads

# ── EC2 port exposed to the internet ────────────────────
BACKEND_PORT=8080

# ── Database ──────────────────────────────────────────────
DB_USER=postgres
DB_PASSWORD=change-me-strong-db-password
DB_NAME=distribution
DB_TIMEZONE=Asia/Kolkata

# ── JWT (use long random strings) ─────────────────────────
JWT_ACCESS_SECRET=change-me-long-random-access-secret
JWT_REFRESH_SECRET=change-me-long-random-refresh-secret
JWT_ACCESS_TTL_MINUTES=15
JWT_REFRESH_TTL_HOURS=168

# ── Seed super admin (first run only) ─────────────────────
SEED_SUPERADMIN_EMAIL=superadmin@company.com
SEED_SUPERADMIN_PASSWORD=ChangeMe@123
SEED_SUPERADMIN_NAME=Super Admin
